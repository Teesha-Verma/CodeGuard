# ──────────────────────────────────────────────────────────────────
# CodeGuard — Environment Configuration
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────
APP_NAME=CodeGuard
DEBUG=true
LOG_LEVEL=DEBUG

# ── Database ─────────────────────────────────────────────────────
# Dev  : sqlite:///./codeguard.db
# Prod : postgresql://user:password@localhost:5432/codeguard
DATABASE_URL=sqlite:///./codeguard.db

# ── LLM Provider ────────────────────────────────────────────────
# Options: "groq" or "openai"
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=60

# ── GitHub ───────────────────────────────────────────────────────
GITHUB_TOKEN=githubtoken

# ── Paths ────────────────────────────────────────────────────────
REPOS_DIR=repos
LOG_DIR=logs

# ── Pipeline ─────────────────────────────────────────────────────
MAX_FILE_SIZE_KB=500
CONTEXT_WINDOW_LINES=10
MAX_DIFF_FILES=50
